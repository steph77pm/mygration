# Mygration backend — local development env
# Copy this file to `.env` and fill in the real values. `.env` is gitignored.
# On Railway, set these in the project's Variables tab instead.

# --- Flask ---
FLASK_DEBUG=true
SECRET_KEY=change-this-to-a-random-string

# --- Database ---
# Leave unset to use local SQLite. Railway injects DATABASE_URL automatically.
# DATABASE_URL=postgresql://user:pass@host:5432/mygration

# --- WeatherAPI.com ---
WEATHER_API_KEY=d60818a7048d44e4bb0164748262101

# --- CORS (frontend origins) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Thresholds (user-configurable later) ---
COLD_THRESHOLD_F=40
HEAT_THRESHOLD_F=80
EXTENDED_DAYS_THRESHOLD=3

# --- Email alerts (Phase 4 — leave blank for now) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_FROM_EMAIL=stephanie.warner77@gmail.com
# ALERT_TO_EMAIL=stephanie.warner77@gmail.com
